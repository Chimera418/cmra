{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "CMRA",
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.cmra",
          "match": "(^|\\s)(murmur\\b|;).*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.cmra",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.cmra",
              "match": "\\\\."
            }
          ]
        },
        {
          "name": "string.quoted.single.cmra",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.cmra",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.cmra",
          "match": "\\b(bind|roar|sniff|dive|soar|print|check|reverse)\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.cmra",
          "match": "\\b\\d+(\\.\\d+)?\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.cmra",
          "match": "(=|\\+|-|\\*|/|<|>|<=|>=|==)"
        }
      ]
    }
  },
  "scopeName": "source.cmra"
}
